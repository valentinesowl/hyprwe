#cloud-config
# HWE cloud-init — runs once on first boot. Double-at tokens are filled in by
# lib/vm.sh before the seed ISO is built.

hostname: @@HOSTNAME@@
manage_etc_hosts: true

# Only the ADMIN group — `wheel` on Arch, `sudo` on Ubuntu.
#
# The seat groups this used to grant (video, input, audio, storage, network) are
# GONE, not moved. They were a pre-logind habit: on a systemd system udev tags
# the seat's devices `uaccess` and logind ACLs them to the ACTIVE session, while
# the compositor never opens /dev/input itself — it is handed an fd by logind's
# TakeDevice. Measured on a working bare-metal HWE box: /dev/dri/card1 carries
# `user:<you>:rw-`, none of the 17 input devices carries any ACL, the user is in
# none of those groups, and Hyprland works. Group membership would only widen
# what EVERY process of that user may read, permanently — including over ssh.
#
# It also stopped porting: Ubuntu has no `storage` or `network` group at all, and
# cloud-init fails the whole user module on the first name that does not resolve.
users:
  - name: @@USER@@
    groups: [@@ADMIN_GROUP@@]
    shell: @@SHELL@@
    lock_passwd: false
    plain_text_passwd: @@PASSWORD@@
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    ssh_authorized_keys:
@@SSH_KEYS@@

# Password SSH is enabled ONLY when no host key was shipped (SSH_KEYS empty),
# so the well-known default password can't be used to log in over the network
# when key auth is already available. lib/vm.sh fills this in.
ssh_pwauth: @@SSH_PWAUTH@@
package_update: true

# Minimal set needed before the HWE installer can take over.
packages:
  - git
  - qemu-guest-agent
  - sudo

runcmd:
  - [systemctl, enable, --now, qemu-guest-agent]
  - |
    set -euxo pipefail
    # The chosen local branch was shipped as a git bundle on the seed ISO.
    seed="$(blkid -L CIDATA 2>/dev/null || echo /dev/sr0)"
    mkdir -p /mnt/hwe-seed
    mount -o ro "$seed" /mnt/hwe-seed
    install -d -o @@USER@@ -g @@USER@@ /home/@@USER@@/hwe
    sudo -u @@USER@@ git clone -b '@@BRANCH@@' /mnt/hwe-seed/hwe.bundle /home/@@USER@@/hwe
    umount /mnt/hwe-seed || true
    # Hand off to the HWE installer (packages + config + Hyprland session).
    # HWE_HYPR_SOURCE carries the host's choice of compositor source into the
    # guest. It is passed separately from HWE_ASSUME_YES on purpose: the blanket
    # yes answers prompts, it does not extend trust to a third-party archive.
    sudo -u @@USER@@ env HWE_ASSUME_YES=1 HWE_UNATTENDED=1 \
      HWE_HYPR_SOURCE='@@HYPR_SOURCE@@' \
      /home/@@USER@@/hwe/bin/hwe install

final_message: "HWE provisioned after $UPTIME s — rebooting into the Hyprland session"

# Reboot once after provisioning. The tty1 autologin drop-in the installer writes
# only takes effect on a fresh getty, so the FIRST boot otherwise leaves a bare
# `login:` that wants the (untypeable, un-pasteable) console password. One reboot
# activates autologin -> Hyprland, so the VM's first presented state is the
# graphical session and the password never appears in the normal flow.
power_state:
  mode: reboot
  message: "HWE provisioned — rebooting into the Hyprland session"
  condition: true
