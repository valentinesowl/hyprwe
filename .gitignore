# HWE — ignore local/runtime cruft

# Reference checkouts of other projects, cloned beside this one while hacking on
# it, are ignored per-clone (.git/info/exclude) rather than named here. The test
# suite guards the index with an allowlist of HWE's own directories, so a stray
# tree fails CI whatever it is called — see tests/test_repo_hygiene.py.

# Claude Code — session state, worktrees, scratch (never part of the project).
/.claude/

# Python bytecode — scripts/ are run directly; importing one in a test
# (as a module, to exercise its functions) drops a __pycache__ next to it.
__pycache__/
*.pyc

# Editor / OS
*.swp
*~
.DS_Store

# Pasted screenshots / scratch images dropped in the repo root.
# NEVER track these: a screenshot of another workspace leaks whatever was on the
# screen — internal hosts, usernames, private tooling. Real assets go to assets/
# or themes/<name>/ deliberately. jpg included after one slipped through.
/*.png
/*.jpg
/*.jpeg
/*.webp

# Per-theme wallpapers. The generated gradient `themes/<name>/wallpaper.png` IS
# tracked — it's 100% ours (computed from the theme palette, no third-party
# image, no licence). An optional LOCAL photo library per theme is NOT: those
# photos are personal, likely third-party copyrighted, and must never ship.
themes/*/wallpapers/

# Runtime state that apps may write into the (symlinked) config dirs
config/hypr/shaders/.compiled.cache.glsl
config/**/.cache/
*.log

# zsh runtime (redirected to XDG state/cache in .zshrc, but guard anyway)
config/zsh/.zsh_history
config/zsh/.zcompdump*
config/zsh/.zsh_sessions/

# Personal Hyprland tweaks belong in ~/.config/hwe/hypr.conf, outside the
# checkout entirely. This entry stays for the machines that predate that layer:
# ~/.config/hypr IS this directory, so a userprefs.conf written there before is
# sitting in the working tree and must not become a tracked file.
config/hypr/userprefs.conf

# Generated by `hwe theme` (regenerate: hwe theme apply <name>) — never tracked
config/hypr/colors.conf
config/hypr/theme.conf
config/hypr/hyprlock.conf
config/mako/config
config/waybar/colors.css
config/waybar/config.jsonc
config/waybar/theme.css
config/kitty/colors.conf
config/kitty/font.conf
config/gtk-3.0/gtk.css
config/gtk-3.0/settings.ini
config/gtk-4.0/gtk.css
config/gtk-4.0/settings.ini
config/kvantum/generalcolors.ini
config/rofi/colors.rasi
config/rofi/wallpaper.rasi
config/rofi/powermenu.rasi
config/rofi/theme.rasi
config/rofi/keys.rasi
config/sddm/theme.conf
config/starship.toml
config/kdeglobals
config/color-schemes/HWE.colors
# Pre-1.4 marker locations — state now lives in ~/.config/hwe/themes/ and is
# migrated on read; stale originals on older installs must stay invisible.
themes/.current

# Active-wallpaper pointer + per-theme remembered choice — machine-local runtime
# state written by `hwe wall` / `hwe theme apply`, never tracked.
config/hypr/assets/current.wall
themes/*/.current_wallpaper
