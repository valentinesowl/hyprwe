/* rofi/colors.rasi — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
   config.rasi does @import "colors.rasi" and uses @accent / @bg / … */

* {
    bg-dark: {{ sem.bg_dark }};
    bg:      {{ sem.bg_normal }};
    bg-alt:  {{ sem.bg_light }};
    fg:      {{ sem.fg_bright }};
    fg-dim:  {{ sem.fg_dim }};
    accent:  {{ sem.accent }};
    urgent:  {{ sem.urgent }};

    /* Default rofi font from the [font] contract (launcher base + 2). config.rasi
       imports this and doesn't set its own font, so the launcher inherits it. */
    font: "{{ font.family }} {{ (font.launcher + 2) | round | int }}";
}
