/* rofi/theme.rasi — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
   The theme gallery (hwe theme pick, SUPER+SHIFT+T): a grid of the per-theme
   poster tiles — nothing but the cards. Each tile already carries its name and its
   own accent border, so there is no label row and no wrapper frame.

   The tiles are SQUARE on purpose. rofi lays element-icon out as a square box of
   `size` and letterboxes the image inside it; `squared: false` is documented but
   applies to the standalone icon widget, not to element-icon in a listview (proven:
   the window measures 940x514 with and without it). A 16:9 tile therefore left ~45px
   of dead box above and below EVERY row — that was the gap between rows and the
   reason the selection floated as an oversized box around the card. genpreview.py
   renders 1:1 so the box is exactly the tile. Regenerate: hwe theme apply <name> */

* {
    fg-dim:       {{ sem.fg_dim }};
    fg-bright:    {{ sem.fg_bright }};
    accent:       {{ sem.accent }};
    transparent:  #00000000;

    font: "{{ font.family }}, {{ font.fallback_family }}, {{ font.icon_family }} {{ (font.launcher - 1) | round | int }}";
    background-color: @transparent;
    text-color: @fg-bright;
}

/* Translucent so `layerrule = blur, match:namespace rofi` (windowrules.conf) has
   something to work on — opaque here and the picker reads as a flat slab laid over
   the wallpaper, with the blur silently doing nothing. Alpha follows the theme's
   own params.opacity so the picker is glass to the same degree as everything else. */
window {
    location:         center;
    anchor:           center;
    width:            940px;
    border:           0;
    border-radius:    {{ params.rounding + 6 }}px;   /* tracks the theme's window rounding */
    background-color: {{ sem.bg_dark | hexa(params.opacity) }};
}

mainbox {
    spacing:          10px;
    children:         [ "inputbar", "listview" ];
    background-color: @transparent;
    padding:          20px;
}

/* a single quiet prompt line; type to filter by name */
inputbar {
    padding:          2px 6px 10px 6px;
    spacing:          8px;
    background-color: @transparent;
    children:         [ "prompt", "entry" ];
}

prompt {
    text-color:       @accent;
    background-color: @transparent;
}

entry {
    placeholder:      "filter…";
    placeholder-color: @fg-dim;
    background-color: @transparent;
}

listview {
    columns:          4;
    lines:            2;
    fixed-height:     false;
    spacing:          12px;
    scrollbar:        false;
    background-color: @transparent;
    dynamic:          true;
}

/* Each element is JUST the tile; the padding is the mat the selection fills.
   4px padding + 2px border below = the old 6px box, so the 940px grid holds. */
element {
    padding:          4px;
    border:           2px;
    border-color:     @transparent;
    border-radius:    14px;
    background-color: @transparent;
    cursor:           pointer;
    children:         [ "element-icon" ];
}

/* Selection = an accent mat plus a ring around it. The mat alone at low alpha
   drowned in bright wallpapers under the blur; the ring keeps the selection
   legible regardless of what is behind the window. The mat separates the
   ring from the tile's OWN accent border, so the two do not read as one frame. */
element selected.normal {
    background-color: {{ sem.accent | hexa(0.40) }};
    border-color:     @accent;
}

element-icon {
    size:             204px;
    horizontal-align: 0.5;
    vertical-align:   0.5;
    background-color: @transparent;
    cursor:           inherit;
}
