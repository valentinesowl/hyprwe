/* rofi/wallpaper.rasi — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
   The wallpaper picker (hwe wall pick, SUPER+SHIFT+W): a tiled grid of thumbnails
   that recolours with the active theme. Regenerate: hwe theme apply <name> */

* {
    bg-dark:      {{ sem.bg_dark }};
    bg-normal:    {{ sem.bg_normal }};
    bg-light:     {{ sem.bg_light }};
    fg-dim:       {{ sem.fg_dim }};
    fg-bright:    {{ sem.fg_bright }};
    fg-white:     {{ sem.fg_white }};
    accent:       {{ sem.accent }};
    accent-soft:  {{ sem.accent_soft }};
    transparent:  #00000000;

    font: "{{ font.family }}, {{ font.fallback_family }}, {{ font.icon_family }} {{ (font.launcher - 1) | round | int }}";
    background-color: @transparent;
    text-color: @fg-bright;
}

window {
    location:         center;
    anchor:           center;
    width:            900px;
    border:           2px;
    border-color:     @accent;
    border-radius:    {{ params.rounding + 6 }}px;   /* tracks the theme's window rounding */
    background-color: @bg-dark;
    transparency:     "real";
}

mainbox {
    spacing:          0px;
    children:         [ "message", "listview" ];
    background-color: @bg-dark;
    padding:          16px;
}

message {
    padding:          8px 12px 16px 12px;
    background-color: @transparent;
}

textbox {
    text-color:       @accent-soft;
    background-color: @transparent;
    horizontal-align: 0.5;
}

listview {
    lines:            2;
    columns:          3;
    fixed-height:     false;
    spacing:          12px;
    scrollbar:        false;
    background-color: @transparent;
    dynamic:          true;
    cycle:            true;
}

element {
    orientation:      vertical;
    padding:          8px;
    spacing:          6px;
    border-radius:    10px;
    background-color: @bg-normal;
    text-color:       @fg-dim;
    cursor:           pointer;
}

element selected.normal {
    background-color: @accent;
    text-color:       @bg-dark;
    border:           2px;
    border-color:     @accent-soft;
}

element-icon {
    size:             200px;
    horizontal-align: 0.5;
    cursor:           inherit;
    background-color: @transparent;
    border-radius:    6px;
}

element-text {
    horizontal-align: 0.5;
    cursor:           inherit;
    background-color: @transparent;
    text-color:       inherit;
    font:             "{{ font.family }}, {{ font.fallback_family }}, {{ font.icon_family }} {{ (font.launcher - 2) | round | int }}";
}
