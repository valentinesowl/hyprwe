/* rofi/keys.rasi — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
   The keybind cheatsheet (hwe keys, SUPER+/): a wide, read-only two-column
   list of shortcuts that recolours with the active theme. Monospace so the
   MOD+KEY column stays aligned. Regenerate: hwe theme apply <name> */

* {
    bg-dark:      {{ sem.bg_dark }};
    bg-normal:    {{ sem.bg_normal }};
    bg-light:     {{ sem.bg_light }};
    fg-dim:       {{ sem.fg_dim }};
    fg-bright:    {{ sem.fg_bright }};
    accent:       {{ sem.accent }};
    urgent:       {{ sem.urgent }};
    transparent:  #00000000;

    font: "{{ font.family }} {{ font.launcher | round | int }}";
    background-color: @transparent;
    text-color: @fg-bright;
}

window {
    location:         center;
    anchor:           center;
    width:            640px;
    border:           2px;
    border-color:     @accent;
    border-radius:    {{ params.rounding + 6 }}px;   /* tracks the theme's window rounding */
    background-color: @bg-dark;
}

mainbox {
    spacing:          0px;
    children:         [ "inputbar", "listview" ];
    background-color: @bg-dark;
    padding:          14px;
}

inputbar {
    padding:          6px 10px 12px 10px;
    spacing:          8px;
    background-color: @transparent;
    children:         [ "prompt", "entry" ];
}

prompt {
    text-color:       @accent;
    background-color: @transparent;
}

entry {
    placeholder:      "фильтр…";
    placeholder-color: @fg-dim;
    background-color: @transparent;
}

listview {
    lines:            16;
    columns:          1;
    scrollbar:        false;
    spacing:          2px;
    background-color: @transparent;
    fixed-height:     false;
}

element {
    padding:          6px 12px;
    border-radius:    8px;
    background-color: @transparent;
    text-color:       @fg-bright;
    cursor:           default;
}

element selected.normal {
    background-color: @bg-normal;
    text-color:       @fg-bright;
}

element-text {
    horizontal-align: 0.0;
    background-color: @transparent;
    text-color:       inherit;
}
