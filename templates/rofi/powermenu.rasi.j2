/* rofi/powermenu.rasi — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
   The session menu (hwe power, SUPER+SHIFT+E): a compact vertical list that
   recolours with the active theme. Regenerate: hwe theme apply <name> */

* {
    bg-dark:      {{ sem.bg_dark }};
    bg-normal:    {{ sem.bg_normal }};
    bg-light:     {{ sem.bg_light }};
    fg-dim:       {{ sem.fg_dim }};
    fg-bright:    {{ sem.fg_bright }};
    accent:       {{ sem.accent }};
    urgent:       {{ sem.urgent }};
    transparent:  #00000000;

    font: "{{ font.family }}, {{ font.fallback_family }}, {{ font.icon_family }} {{ (font.launcher + 1) | round | int }}";
    background-color: @transparent;
    text-color: @fg-bright;
}

window {
    location:         center;
    anchor:           center;
    width:            300px;
    border:           2px;
    border-color:     @accent;
    border-radius:    {{ params.rounding + 6 }}px;   /* tracks the theme's window rounding */
    background-color: @bg-dark;
}

mainbox {
    spacing:          0px;
    children:         [ "message", "listview" ];
    background-color: @bg-dark;
    padding:          14px;
}

message {
    padding:          6px 10px 12px 10px;
    background-color: @transparent;
}

textbox {
    text-color:       @fg-dim;
    background-color: @transparent;
    horizontal-align: 0.5;
}

listview {
    lines:            5;
    columns:          1;
    scrollbar:        false;
    spacing:          4px;
    background-color: @transparent;
}

element {
    padding:          10px 14px;
    border-radius:    10px;
    background-color: @bg-normal;
    text-color:       @fg-bright;
    cursor:           pointer;
}

element selected.normal {
    background-color: @accent;
    text-color:       @bg-dark;
}

element-text {
    horizontal-align: 0.0;
    background-color: @transparent;
    text-color:       inherit;
}
