# hypr/theme.conf — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
# Owns the per-theme visuals: the animated ("shimmering") border AND window
# translucency. Regenerate: hwe theme apply <name>
# Sourced AFTER appearance.conf, so it overrides the border/opacity there.

general {
    # Gradient stops flow around the focused window as the angle rotates below.
    col.active_border = {% for c in params.border_gradient %}{{ c | rgba }} {% endfor %}{{ params.border_angle }}deg
    col.inactive_border = {{ params.border_inactive | rgba }}
    # Border thickness and window gaps are per-theme too (appearance.conf holds
    # the pre-theme baseline; these override it).
    border_size = {{ params.border_size }}
    gaps_in = {{ params.gaps_in }}
    gaps_out = {{ params.gaps_out }}
}

# Corner rounding + window blur (override appearance.conf's baseline). Window
# translucency is NOT set here — it's the global opacity windowrule below.
decoration {
    rounding = {{ params.rounding }}
    # Window blur strength — per-theme. Only these two keys override the blur{}
    # block in appearance.conf; enabled/xray/etc. stay there (Hyprland merges
    # nested blocks by key). blur_size = radius, blur_passes = passes.
    blur {
        size = {{ params.blur_size }}
        passes = {{ params.blur_passes }}
    }
}

# Whole-window translucency for EVERY window (match:class .*), so Hyprland's blur
# shows through all of them — browsers, editors, chat, not just terminals. Opaque
# windows can't reveal any blur behind them, so uniform blur REQUIRES uniform
# translucency. The three opacity values are active / inactive / FULLSCREEN: the
# 3rd pins fullscreen back to 1.0 so fullscreen video & games stay crisp.
windowrule = opacity {{ params.active_opacity }} {{ params.inactive_opacity }} 1.0, match:class .*

# Animations — per-theme SPEED. appearance.conf holds the pre-theme baseline (and
# the bezier curve definitions, which we reuse by name here); this block overrides
# the durations, scaled by the theme's `anim_speed` (higher = snappier). A quiet
# theme can slow the desktop down; `anim_speed = 0` turns motion off entirely.
animations {
{% if params.anim %}
    enabled = 1
    animation = windows,     1, {{ params.anim.windows }}, wind,      slide
    animation = windowsIn,   1, {{ params.anim.windowsIn }}, overshot,  slide
    animation = windowsOut,  1, {{ params.anim.windowsOut }}, smoothOut, slide
    animation = windowsMove, 1, {{ params.anim.windowsMove }}, wind,      slide
    animation = border,      1, {{ params.anim.border }}, default
    animation = fade,        1, {{ params.anim.fade }}, smoothIn
    animation = workspaces,  1, {{ params.anim.workspaces }}, wind
{% if params.border_animate %}
    # Signature shimmer: rotate the gradient angle forever. Lower number =
    # faster/louder (Neon); higher = a quiet shimmer; border_animate = 0 = static.
    animation = borderangle, 1, {{ params.border_animate }}, linear, loop
{% endif %}
{% else %}
    # anim_speed = 0 — the whole desktop is still. (This also stills the border
    # shimmer, since that is an animation too.)
    enabled = 0
{% endif %}
}
