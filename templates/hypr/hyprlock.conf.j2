# hyprlock.conf — GENERATED by `hwe theme apply` from the active theme's [sem].
# Do NOT edit; edit templates/hypr/hyprlock.conf.j2 or the theme's roles instead.

background {
    monitor =
    # $HOME, NOT ~ — hyprlang expands env vars but not a leading ~ (same gotcha
    # as hyprpaper), so `~/…` would fall back to the solid `color` below.
    path = $HOME/.config/hypr/assets/current.wall
    blur_passes = {{ params.blur_passes }}
    blur_size = {{ params.blur_size }}
    color = {{ sem.bg_normal|rgb }}
}

general {
    hide_cursor = true
    grace = 0        # no passwordless window after lock (incl. manual Super+L)
}

# Password input field.
input-field {
    monitor =
    size = 320, 52
    outline_thickness = 2
    dots_size = 0.28
    dots_spacing = 0.32
    dots_center = true
    rounding = {{ params.rounding }}
    outer_color = {{ sem.accent|rgb }}
    inner_color = {{ sem.bg_light|rgb }}
    font_color = {{ sem.fg_bright|rgb }}
    placeholder_text = <span foreground="##{{ sem.fg_normal|noh }}">Enter password…</span>
    fail_color = {{ sem.red|rgb }}
    fail_text = <span foreground="##{{ sem.red|noh }}">$FAIL ($ATTEMPTS)</span>
    position = 0, -40
    halign = center
    valign = center
}

# Keyboard-layout indicator (live via $LAYOUT). Sits just below the input field
# so you can confirm us/ru at a glance — Super+Space cycles it (bindl in
# keybindings.conf, the `l` flag lets the bind fire while locked).
label {
    monitor =
    text = $LAYOUT
    font_size = 14
    font_family = {{ font.family }}
    color = {{ sem.fg_normal|rgb }}
    position = 0, -104
    halign = center
    valign = center
}

# Big clock.
label {
    monitor =
    text = cmd[update:1000] date +"%H:%M"
    font_size = 96
    font_family = {{ font.family }}
    color = {{ sem.fg_bright|rgb }}
    position = 0, 160
    halign = center
    valign = center
}

# Date + user.
label {
    monitor =
    text = cmd[update:60000] date +"%A, %d %B"
    font_size = 20
    font_family = {{ font.family }}
    color = {{ sem.fg_normal|rgb }}
    position = 0, 60
    halign = center
    valign = center
}
