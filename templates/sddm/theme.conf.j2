[General]
# sddm/theme.conf — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
# Synced into /usr/share/sddm/themes/hwe/ by `hwe theme sddm` (needs root).
# Main.qml reads every key below as config.<Key>.

# Background is the active wallpaper, copied in next to Main.qml at sync time.
Background="background.png"
FontFamily="{{ font.family | default('sans-serif') }}"
Radius="{{ params.rounding | default(12) }}"

BgColor="{{ sem.bg_dark }}"
FieldBg="{{ sem.bg_light }}"
FgColor="{{ sem.fg_bright }}"
FgDim="{{ sem.fg_dim }}"
Accent="{{ sem.accent }}"
Error="{{ sem.urgent }}"
