{# HWE.colors — GENERATED by `hwe theme apply`. A real KDE colour-scheme file
   deployed to ~/.local/share/color-schemes/ so kdeglobals' ColorScheme=HWE
   resolves and KColorScheme applies it fully (no partial Breeze fallback). #}
[ColorEffects:Disabled]
Color={{ sem.bg_light|kcol }}
ColorAmount=0
ColorEffect=0
ContrastAmount=0.65
ContrastEffect=1
IntensityAmount=0.1
IntensityEffect=2

[ColorEffects:Inactive]
ChangeSelectionColor=false
Color={{ sem.bg_light|kcol }}
ColorAmount=0
ColorEffect=0
ContrastAmount=0.1
ContrastEffect=0
Enable=false
IntensityAmount=0
IntensityEffect=0

{% include '_kde_colors.ini' %}

[WM]
activeBackground={{ sem.bg_dark|kcol }}
activeForeground={{ sem.fg_white|kcol }}
activeBlend={{ sem.accent|kcol }}
inactiveBackground={{ sem.bg_normal|kcol }}
inactiveForeground={{ sem.fg_normal|kcol }}
inactiveBlend={{ sem.bg_light|kcol }}

[General]
ColorScheme=HWE
Name=HWE
shadeSortColumn=true
