# starship.toml — GENERATED by `hwe theme apply` from templates/starship.toml.j2
# Do NOT edit this file; edit the template or the theme's [sem] roles instead.
# Single line, minimalist. Colours come from the active theme's semantic roles,
# so the prompt recolours together with hypr/waybar/kitty/rofi.

add_newline = false
command_timeout = 800

# One line: dir  branch  git-state   langs  duration  ❯
format = """
$directory\
$git_branch\
$git_status\
$python$nodejs$rust\
$cmd_duration\
$character"""

palette = "hwe"

# Mapped from the theme's semantic roles ({{ name }} theme).
[palettes.hwe]
accent = "{{ sem.accent }}"
blue   = "{{ sem.blue }}"
green  = "{{ sem.green }}"
red    = "{{ sem.red }}"
orange = "{{ sem.orange }}"
text   = "{{ sem.fg_normal }}"

[directory]
style = "bold blue"
format = "[$path]($style) "
truncation_length = 3
truncate_to_repo = true
read_only = " "

[git_branch]
symbol = " "
style = "bold accent"
format = "[$symbol$branch]($style) "

[git_status]
style = "red"
format = "([$all_status$ahead_behind]($style) )"
conflicted = "="
ahead = "⇡${count}"
behind = "⇣${count}"
diverged = "⇕⇡${ahead_count}⇣${behind_count}"
untracked = "?"
stashed = "≡"
modified = "!"
staged = "+"
renamed = "»"
deleted = "✘"

[python]
symbol = " "
style = "green"
format = '[$symbol($version )]($style)'

[nodejs]
symbol = " "
style = "green"
format = '[$symbol($version )]($style)'

[rust]
symbol = " "
style = "orange"
format = '[$symbol($version )]($style)'

[cmd_duration]
min_time = 500
style = "orange"
format = "[󱎫 $duration]($style) "

[character]
success_symbol = "[❯](bold green)"
error_symbol = "[❯](bold red)"
vimcmd_symbol = "[❮](bold accent)"
