# gtk-4.0/settings.ini — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
# GTK4/libadwaita apps ignore gtk-theme-name; their colours come from the
# generated gtk-4.0/gtk.css. This file sets the light/dark preference, icons,
# cursor and fonts — themed via [params]/[font]. The scheme is also nudged via
# `gsettings color-scheme` on apply.
[Settings]
gtk-application-prefer-dark-theme={{ params.prefer_dark }}
gtk-icon-theme-name={{ params.icon_theme }}
gtk-font-name={{ font.ui_family }} {{ font.gtk }}
{% if params.cursor_theme %}gtk-cursor-theme-name={{ params.cursor_theme }}
{% endif %}gtk-cursor-theme-size=24
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintslight
gtk-xft-rgba=rgb
