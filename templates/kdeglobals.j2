{# kdeglobals — GENERATED by `hwe theme apply` from the theme's [sem].
   KDE/KF6 apps (Dolphin, Ark, …) colour themselves from KColorScheme. This
   points them at the generated HWE.colors scheme (in ~/.local/share/color-
   schemes) AND carries the same colours inline as a fallback, and sets the
   Fusion widget style. qt6ct handles the remaining non-KDE Qt apps. #}
[General]
ColorScheme=HWE
Name=HWE
TerminalApplication=kitty
shadeSortColumn=true

[KDE]
widgetStyle=Fusion

[UiSettings]
ColorScheme=HWE

{% include '_kde_colors.ini' %}
