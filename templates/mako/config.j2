# mako/config — GENERATED by `hwe theme apply` from the active theme's [sem].
# Do NOT edit; edit templates/mako/config.j2 or the theme's roles instead.
# Reload after a theme change with:  makoctl reload  (hwe theme apply does this).

font={{ font.family }}, {{ font.fallback_family }}, {{ font.icon_family }} {{ font.notify }}
width=360
height=120
margin=10
padding=14
border-size={{ params.border_size }}
border-radius={{ params.rounding }}
icon-radius=8
max-icon-size=48
default-timeout=6000
ignore-timeout=1

background-color={{ sem.bg_normal }}
text-color={{ sem.fg_bright }}
border-color={{ sem.accent }}
progress-color=over {{ sem.bg_light }}

[urgency=low]
border-color={{ sem.info }}

[urgency=high]
border-color={{ sem.urgent }}
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category
