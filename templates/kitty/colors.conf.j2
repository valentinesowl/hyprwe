# kitty/colors.conf — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
# kitty.conf does `include colors.conf`. Regenerate: hwe theme apply <name>

# Terminal translucency — a theme param (not a colour), but this is the only
# kitty file `hwe theme` generates, and its `include` lands after kitty.conf's
# own line, so setting it here lets the theme own the terminal's opacity.
background_opacity {{ params.opacity }}

foreground {{ sem.fg_bright }}
background {{ sem.bg_normal }}
selection_foreground {{ sem.bg_normal }}
selection_background {{ sem.fg_dim }}
cursor {{ sem.accent }}
cursor_text_color {{ sem.bg_normal }}
url_color {{ sem.accent_soft }}

active_border_color   {{ sem.accent }}
inactive_border_color {{ sem.bg_lighter }}
active_tab_foreground   {{ sem.bg_dark }}
active_tab_background    {{ sem.accent }}
inactive_tab_foreground {{ sem.fg_normal }}
inactive_tab_background {{ sem.bg_dark }}

# ANSI black (0/8) and white (7/15) are scheme-aware: "black" must be the DARK
# end and "white" the LIGHT end whichever way the theme runs, or a light theme
# would paint ANSI-black text in a pale surface colour (invisible). The role
# extremes flip with the scheme (in a light theme fg_* is the dark ink and bg_*
# the light paper), so we swap which role feeds black vs white.
# normal
{% if params.is_light %}
color0 {{ sem.fg_normal }}
color7 {{ sem.bg_light }}
{% else %}
color0 {{ sem.bg_light }}
color7 {{ sem.fg_normal }}
{% endif %}
color1 {{ sem.red }}
color2 {{ sem.green }}
color3 {{ sem.yellow }}
color4 {{ sem.blue }}
color5 {{ sem.magenta }}
color6 {{ sem.cyan }}
# bright
{% if params.is_light %}
color8  {{ sem.fg_dim }}
color15 {{ sem.bg_lighter }}
{% else %}
color8  {{ sem.bg_lighter }}
color15 {{ sem.fg_bright }}
{% endif %}
color9  {{ sem.red }}
color10 {{ sem.green }}
color11 {{ sem.yellow }}
color12 {{ sem.blue }}
color13 {{ sem.magenta }}
color14 {{ sem.cyan }}
