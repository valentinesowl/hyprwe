# gtk-3.0/settings.ini — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
# Colours come from the generated gtk.css; this file sets the base theme, light/
# dark preference, icons, cursor and fonts — all themed via [params]/[font].
# Regenerate: hwe theme apply <name>.
#
# Defaults keep the historic look: plain Adwaita, dark. A theme overrides via
# gtk_theme / icon_theme / cursor_theme / scheme in [params] and [font].ui_family.
# For the unified libadwaita look on GTK3, install adw-gtk3 (see pkg/aur.lst) and
# set gtk_theme = "adw-gtk3-dark" in the theme.
[Settings]
gtk-theme-name={{ params.gtk_theme }}
gtk-icon-theme-name={{ params.icon_theme }}
gtk-application-prefer-dark-theme={{ params.prefer_dark }}
gtk-font-name={{ font.ui_family }} {{ font.gtk }}
{% if params.cursor_theme %}gtk-cursor-theme-name={{ params.cursor_theme }}
{% endif %}gtk-cursor-theme-size=24
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintslight
gtk-xft-rgba=rgb
gtk-toolbar-style=GTK_TOOLBAR_ICONS
gtk-button-images=0
gtk-menu-images=0
gtk-enable-event-sounds=1
gtk-enable-input-feedback-sounds=0
