// waybar/config.jsonc â€” GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
// Regenerate with: hwe theme apply <name>.  (Source: templates/waybar/config.jsonc.j2)
//
// The HWE status bar: thin, quiet, iconic. Left: tiny workspace
// numbers, the focused one marked in the theme's own way (`bar_ws_indicator`).
// Center: date.time. Right: tray + glyph-only indicators â€” every widget there is
// a single Nerd Font glyph that MORPHS with its level (volume, brightness,
// battery, cpu, ram, temperature); exact readings live in the tooltip, never in
// the bar.
// Monochrome by design; colour is for alerts.
//
// GEOMETRY IS THEMED: the bar is glued & flat unless a theme sets `bar_float = true`
// in its [params] â€” then it detaches by `bar_gap`/`bar_gap_x` (these JSON margins,
// because CSS margin on window#waybar is unreliable) and rounds via theme.css.
{
    "layer": "top",
    "position": "top",
    "height": {{ params.bar_height }},
    "spacing": 4,
    "margin-top": {{ params.bar_gap if params.bar_float else 0 }},
    "margin-left": {{ params.bar_gap_x if params.bar_float else 0 }},
    "margin-right": {{ params.bar_gap_x if params.bar_float else 0 }},

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/cpu", "custom/memory", "custom/temp", "custom/record", "tray", "pulseaudio", "backlight", "battery"],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "sort-by-number": true
    },

    "clock": {
        "format": "{:%d.%m  %H:%M}",
        "format-alt": "{:%A, %d %B %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    // Volume: glyph tracks the level (low/med/high); headphones/headset when routed.
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "headphone": "َ°‹‹",
            "headset": "َ°‹ژ",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "tooltip-format": "{desc} â€” {volume}%",
        "on-click": "pavucontrol",
        "on-click-right": "swayosd-client --output-volume mute-toggle",
        "on-scroll-up": "swayosd-client --output-volume raise",
        "on-scroll-down": "swayosd-client --output-volume lower"
    },

    // Screen brightness â€” a sun that gains rays as it brightens (7 steps).
    // Laptop-only; the module hides itself when no backlight device exists (VM).
    "backlight": {
        "format": "{icon}",
        "format-icons": ["َ°ƒڑ", "َ°ƒ›", "َ°ƒœ", "َ°ƒ‌", "َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "tooltip-format": "Brightness: {percent}%",
        "on-scroll-up": "swayosd-client --brightness raise",
        "on-scroll-down": "swayosd-client --brightness lower"
    },

    // Wi-Fi/VPN/network live in the nm-applet tray icon (full GTK menu),
    // so there is no waybar network module â€” one wifi indicator, functional.

    // Battery: glyph fills with charge; a bolt while charging, a plug on AC.
    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon}",
        "format-charging": "َ°‚„",
        "format-plugged": "َ°ڑ¥",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip-format": "{capacity}% â€” {timeTo} ({power}W)"
    },

    // CPU / RAM: glyph-only, like every other indicator on this side. wbstat.py
    // reports a percentage and Waybar picks the glyph from it (format-icons, low
    // -> high) â€” no text in the bar at all. The two use deliberately different
    // shapes so they never blur together at 12px: CPU rides a speedometer (how
    // FAST it's going), RAM fills a pie (how FULL it is). The exact % and the
    // rolling sparkline (â–پâ–‚â–ƒâ–„â–…â–†â–‡â–ˆ, history kept in ~/.cache/hwe) live in the
    // tooltip, where a precise reading belongs.
    "custom/cpu": {
        "format": "{icon}",
        "format-icons": ["َ°¾†", "َ°¾…", "َ°“…"],
        "return-type": "json",
        "interval": 2,
        "exec": "python3 {{ scripts_dir }}/wbstat.py cpu",
        "on-click": "kitty -e btop"
    },

    "custom/memory": {
        "format": "{icon}",
        "format-icons": ["َ°ھ‍", "َ°ھں", "َ°ھ ", "َ°ھ،", "َ°ھ¢", "َ°ھ£", "َ°ھ¤", "َ°ھ¥"],
        "return-type": "json",
        "interval": 2,
        "exec": "python3 {{ scripts_dir }}/wbstat.py mem",
        "on-click": "kitty -e btop"
    },

    // CPU temperature: a thermometer that fills as the die heats. Same contract
    // as its neighbours â€” one glyph, exact آ°C in the tooltip.
    //
    // NOT Waybar's built-in `temperature` module, deliberately: that one is
    // addressed by PATH, and no path travels between machines. /sys/class/hwmon
    // numbering is probe-order and shifts between boots, and AMD's sensor sits
    // on a PCI address that differs across Ryzen/Threadripper/EPYC. wbstat.py
    // instead finds the sensor by its chip NAME (coretemp/k10temp/...), which is
    // stable, and scales the ramp to that sensor's OWN critical point â€” so this
    // reads right on Intel and AMD, laptop and desktop, without a per-host edit.
    //
    // exec-if: where no CPU sensor exists at all (a VM with nothing passed
    // through), the module never runs and the glyph is simply absent.
    "custom/temp": {
        "format": "{icon}",
        "format-icons": ["َ±ƒƒ", "َ°”ڈ", "َ±ƒ‚"],
        "return-type": "json",
        "interval": 4,
        "exec": "python3 {{ scripts_dir }}/wbstat.py temp",
        "exec-if": "python3 {{ scripts_dir }}/wbstat.py temp --probe",
        "on-click": "kitty -e btop"
    },

    // Recording indicator: hidden while idle, shows â—ڈ REC during a wf-recorder
    // capture (hwe record). Click to stop. Polls the process directly (cheap).
    "custom/record": {
        "format": "{}",
        "interval": 1,
        "exec": "pgrep -x wf-recorder >/dev/null && echo 'â—ڈ  REC' || echo ''",
        "on-click": "hwe record",
        "tooltip": false
    },

    "tray": {
        "icon-size": 14,
        "spacing": 8
    }
}
