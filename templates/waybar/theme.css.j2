/* waybar/theme.css — GENERATED by `hwe theme` from "{{ name }}". DO NOT EDIT.
   style.css does @import "theme.css". (Source: templates/waybar/theme.css.j2)

   The bar's island geometry is a per-theme param. Set `bar_float = true` in a
   theme's [params] to detach & round the bar into a frosted island; otherwise
   the bar stays glued to the top edge, flat and square. (The detach GAP itself
   lives in config.jsonc margins — CSS margin on window#waybar is unreliable,
   Waybar #1533 — so here we only do the rounding/border/shadow.) */

/* Bar font family + size from the theme's [font] contract. style.css no longer
   sets these on `*`, so these values are the ones that apply. */
* {
    font-family: "{{ font.family }}", "Noto Sans", sans-serif;
    font-size: {{ font.bar }}px;
}

/* Bar backdrop: a frosted layer over the wallpaper. Alpha is themed (bar_opacity)
   rather than a literal in style.css, so a theme sets how much glass the bar is;
   the `blur true` waybar layerrule works on whatever shows through. This lives in
   the generated theme.css (imported after style.css) so the themed value wins. */
window#waybar {
    background: alpha(@bg_dark, {{ params.bar_opacity }});
}

{% if params.bar_float %}
/* Floating frosted island: rounded, hairline-bordered, gently shadowed. */
window#waybar {
    border: 1px solid alpha(@fg_dim, 0.14);
    border-radius: {{ params.bar_radius }}px;
    box-shadow: 0 3px 14px alpha(@bg_dark, 0.55);
}
{% else %}
/* Glued to the top edge: no rounding, no border, no float shadow. */
window#waybar {
    border: none;
    border-radius: 0;
    box-shadow: none;
}
{% endif %}

/* ── Workspaces: the focus indicator is a per-theme look ───────────────────
   Set `bar_ws_indicator` in a theme's [params] to one of: glow (default),
   underline, pill, dot; `bar_ws_speed` (ms) tunes how fast it settles.

   The WHOLE #workspaces block lives here, not in style.css: style.css does
   @import "theme.css", so its rules come later and would win on any selector
   we also used there. Same reason the bar font is set here.

   No style MOVES the indicator between tags — GTK3 CSS has no `transform` and
   each tag is a separate GtkButton, so a marker that slides across the group is
   impossible. Focus fades out where it was and grows in where it went; only
   `pill` shifts anything, by widening and nudging its neighbours. Everything
   below animates only GTK-animatable properties. */
#workspaces {
    padding: 0 2px;
}

#workspaces button {
    padding: 0 7px;
    margin: 4px 2px;
    color: @fg_dim;
    background-color: transparent;
    background-image: none;
    border: none;
    box-shadow: none;
    text-shadow: none;
    transition: all {{ params.bar_ws_speed }}ms ease;
}

/* Hover before .active: equal specificity, so the active tag keeps its look
   while the pointer is over it. */
#workspaces button:hover {
    color: @fg_bright;
}
{% if params.bar_ws_indicator == "glow" %}

/* glow — the tag lights up in place: accent ink plus a soft halo on the text
   itself (text-shadow, not a box shadow, so no rectangle floats behind it). */
#workspaces button.active {
    color: @accent;
    text-shadow: 0 0 8px alpha(@accent, 0.75), 0 0 16px alpha(@accent, 0.4);
}
{% elif params.bar_ws_indicator == "underline" %}

/* underline — a solid accent bar drawn as a BACKGROUND (not a border), so its
   width can animate: background-size grows 0% -> 100% pinned at centre bottom,
   which reads as the rule spreading out from under the number. */
#workspaces button {
    background-image: linear-gradient(to top, @accent, @accent);
    background-repeat: no-repeat;
    background-position: center 100%;
    background-size: 0% 2px;
}

#workspaces button.active {
    color: @accent;
    background-size: 100% 2px;
}
{% elif params.bar_ws_indicator == "pill" %}

/* pill — the active tag widens (min-width) into a SOLID accent chip, physically
   pushing its neighbours aside: the one style where the whole group moves. The
   ink is @on_accent (auto-derived to stay legible on the fill), so the number
   reads on a hot-pink chip as clearly as on a pale-cyan one. */
#workspaces button {
    min-width: 0px;
    border-radius: {{ params.rounding }}px;
}

#workspaces button.active {
    color: @on_accent;
    background-color: @accent;
    min-width: 22px;
}
{% elif params.bar_ws_indicator == "dot" %}

/* dot — a small accent mark that rises into view from below the tag: it lives
   at 200% (outside the box, clipped away) and animates up to the bottom edge. */
#workspaces button {
    background-image: linear-gradient(to top, @accent, @accent);
    background-repeat: no-repeat;
    background-size: 5px 2px;
    background-position: center 200%;
}

#workspaces button.active {
    color: @accent;
    background-position: center 100%;
}
{% endif %}

/* Urgent outranks focus, in every style. */
#workspaces button.urgent {
    color: @urgent;
    text-shadow: 0 0 8px alpha(@urgent, 0.7);
}
